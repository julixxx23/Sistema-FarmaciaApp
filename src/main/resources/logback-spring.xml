<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Propiedades de Loki desde application.yml -->
    <springProperty name="LOKI_URL"      source="loki.url"      defaultValue=""/>
    <springProperty name="LOKI_USERNAME" source="loki.username"  defaultValue=""/>
    <springProperty name="LOKI_PASSWORD" source="loki.password"  defaultValue=""/>

    <!-- Consola activa en todos los perfiles -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Dev: solo consola -->
    <springProfile name="dev">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- Prod: consola + Loki (Grafana Cloud) -->
    <springProfile name="prod">

        <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
            <http>
                <url>${LOKI_URL}</url>
                <auth>
                    <username>${LOKI_USERNAME}</username>
                    <password>${LOKI_PASSWORD}</password>
                </auth>
            </http>
            <format>
                <!-- Etiquetas para filtrar en Grafana -->
                <label>
                    <pattern>app=AppOchoa,env=production,level=%level</pattern>
                </label>
                <!-- Formato del mensaje de log -->
                <message>
                    <pattern>%d{HH:mm:ss} %-5level [%thread] %logger - %msg%n</pattern>
                </message>
            </format>
        </appender>

        <root level="WARN">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="LOKI"/>
        </root>

    </springProfile>

</configuration>